# Plex connection (required)
PLEXFILTER_PLEX_URL=http://localhost:32400
PLEXFILTER_PLEX_TOKEN=your_token_here

# Database and output paths
PLEXFILTER_DATABASE_PATH=plexfilter.db
PLEXFILTER_PLEXAUTOSKIP_JSON_PATH=custom.json

# Local nudity detection (fallback when VidAngel has no match)
PLEXFILTER_LOCAL_DETECTION_ENABLED=true
PLEXFILTER_LOCAL_DETECTION_SAMPLE_INTERVAL_SEC=1.0
PLEXFILTER_LOCAL_DETECTION_NUDENET_THRESHOLD=0.40
PLEXFILTER_LOCAL_DETECTION_MERGE_GAP_SEC=1.5

# Stage-1 Freepik fast-pass classifier (optional, requires GPU + torch)
# Set to "none" to skip stage-1 and run NudeNet on all frames
PLEXFILTER_LOCAL_DETECTION_STAGE1_MODEL=freepik
PLEXFILTER_LOCAL_DETECTION_STAGE1_SEVERITY=medium
PLEXFILTER_LOCAL_DETECTION_STAGE1_MIN_VRAM_GB=3.5
PLEXFILTER_LOCAL_DETECTION_STAGE1_REQUIRE_BF16=false
