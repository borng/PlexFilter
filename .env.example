# ── Plex connection ──────────────────────────────────────────────
PLEXFILTER_PLEX_URL=http://localhost:32400
PLEXFILTER_PLEX_TOKEN=your-plex-token

# ── Database ─────────────────────────────────────────────────────
PLEXFILTER_DATABASE_PATH=plexfilter.db

# ── PlexAutoSkip output ──────────────────────────────────────────
PLEXFILTER_PLEXAUTOSKIP_JSON_PATH=custom.json

# ── VidAngel API ─────────────────────────────────────────────────
PLEXFILTER_VIDANGEL_BASE_URL=https://api.vidangel.com/api

# ── Local NSFW detection (optional) ─────────────────────────────
# Enable local frame-level NSFW detection (must be explicitly enabled)
PLEXFILTER_DETECTION_ENABLED=false
# Device for inference: auto | cpu | cuda
PLEXFILTER_DETECTION_DEVICE=auto
# NudeNet model variant: 320n (faster/smaller) or 640m (more accurate)
PLEXFILTER_DETECTION_MODEL=320n
# Seconds between sampled frames during detection
PLEXFILTER_DETECTION_FRAME_INTERVAL=1.0
# Minimum confidence threshold for a detection to count
PLEXFILTER_DETECTION_CONFIDENCE=0.6
# Merge detected segments that are within this many seconds of each other
PLEXFILTER_DETECTION_MERGE_GAP=2.0
